# === LLM (via LiteLLM) ===
# Format : "<provider>/<model>". Voir https://docs.litellm.ai/docs/providers
LLM_MODEL=anthropic/claude-sonnet-4-5
LLM_FALLBACK_MODEL=openai/gpt-4o-mini

# Clés API — uniquement celles correspondant aux modèles utilisés
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GEMINI_API_KEY=
# MISTRAL_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434  # si modèle local

# === Sources ===
NEWSAPI_KEY=
PAPPERS_API_KEY=
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# === Notification ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
DIGEST_TO_EMAIL=
DIGEST_FROM_EMAIL=
# Alternative à SMTP :
# RESEND_API_KEY=

# === Runtime ===
DIGEST_SEND_HOUR=7
DIGEST_TIMEZONE=Europe/Paris
# If set, the digest renders "Marquer comme contacte" links pointing at this
# base URL (e.g. https://tracker.yourdomain.com).
DASHBOARD_BASE_URL=
LOG_LEVEL=INFO

# === Database ===
# Dev: leave DATABASE_URL empty, falls back to the SQLite file at DB_PATH.
# Prod: set DATABASE_URL and ignore DB_PATH.
DB_PATH=data/signals.db
# DATABASE_URL=postgresql+psycopg://signaltracker:changeme@db:5432/signaltracker

# === Dashboard auth (prod only) ===
# When DASHBOARD_AUTH_USER is set, the dashboard requires HTTP Basic Auth on
# every route except /healthz. Leave empty in dev to disable auth.
DASHBOARD_AUTH_USER=
DASHBOARD_AUTH_PASSWORD=

# === Postgres (only used by docker-compose to provision the db service) ===
POSTGRES_USER=signaltracker
POSTGRES_PASSWORD=changeme-please
POSTGRES_DB=signaltracker
