<!doctype html>
<html lang="fr">
<head>
<meta charset="utf-8">
<title>{% block title %}Signal Tracker{% endblock %}</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #15a05a;
    --green-dark: #0c6b3c;
    --green-darker: #0b3d2e;
    --green-soft: #e8f6ed;
    --green-soft-2: #d6efdf;
    --ink: #0b1f17;
    --muted: #5b6b63;
    --muted-2: #93a39a;
    --cream: #f5f7f3;
    --card: #ffffff;
    --border: #e4e9e5;
    --border-strong: #cdd6d0;
    --amber: #b45309;
    --amber-soft: #fef3e2;
    --blue: #1d6fb8;
    --blue-soft: #e8f1f9;
    --red: #b91c1c;
    --red-soft: #fdecec;
    --shadow: 0 1px 2px rgba(11,61,46,0.04), 0 8px 24px rgba(11,61,46,0.06);
  }
  * { box-sizing: border-box; }
  html, body { height: 100%; }
  body {
    margin: 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: var(--cream);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
  }
  a { color: var(--green-dark); text-decoration: none; }
  a:hover { text-decoration: underline; }
  h1, h2, h3 { letter-spacing: -0.02em; }

  /* ---------------- App bar ---------------- */
  header.appbar {
    background: rgba(255,255,255,0.85);
    backdrop-filter: saturate(150%) blur(8px);
    border-bottom: 1px solid var(--border);
    padding: 14px 28px;
    display: flex;
    align-items: center;
    gap: 18px;
    position: sticky;
    top: 0;
    z-index: 20;
  }
  .brand {
    display: inline-flex; align-items: center; gap: 9px;
    font-weight: 800; font-size: 18px; color: var(--green-darker);
  }
  .brand .logo {
    width: 26px; height: 26px; border-radius: 8px;
    background: linear-gradient(135deg, var(--green) 0%, var(--green-dark) 100%);
    display: inline-flex; align-items: center; justify-content: center;
    color: white; font-size: 15px; font-weight: 800;
  }
  .nav { display: flex; gap: 4px; margin-left: 10px; }
  .nav a {
    padding: 7px 14px; border-radius: 8px; font-size: 14px; font-weight: 500;
    color: var(--muted);
  }
  .nav a:hover { background: var(--green-soft); color: var(--green-dark); text-decoration: none; }
  .nav a.active { background: var(--green-soft); color: var(--green-dark); }
  .spacer { flex: 1; }
  .status-pill {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 5px 12px; border-radius: 999px; font-size: 12.5px; font-weight: 500;
    background: var(--cream); color: var(--muted); border: 1px solid var(--border);
  }
  .status-pill.running { background: var(--green-soft); color: var(--green-dark); border-color: var(--green-soft-2); }
  .status-pill.done { background: var(--green-soft); color: var(--green-dark); border-color: var(--green-soft-2); }
  .status-pill.failed { background: var(--red-soft); color: var(--red); border-color: #f6cccc; }
  .spinner {
    width: 12px; height: 12px; border: 2px solid currentColor;
    border-right-color: transparent; border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ---------------- Buttons ---------------- */
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    border: none; border-radius: 10px; font-size: 14px; font-weight: 600;
    cursor: pointer; padding: 10px 18px; transition: all 120ms ease;
    font-family: inherit;
  }
  .btn-primary { background: var(--green); color: white; }
  .btn-primary:hover { background: var(--green-dark); }
  .btn-primary:disabled { background: var(--muted-2); cursor: not-allowed; }
  .btn-ghost { background: white; color: var(--ink); border: 1px solid var(--border-strong); }
  .btn-ghost:hover { border-color: var(--green); color: var(--green-dark); }
  .btn-lg { padding: 14px 28px; font-size: 16px; border-radius: 12px; }

  /* ---------------- Layout ---------------- */
  main { max-width: 1240px; margin: 0 auto; padding: 28px; }

  .card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 16px; padding: 22px 24px; box-shadow: var(--shadow);
  }
  .card h2 {
    margin: 0 0 16px; font-size: 13px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.06em; color: var(--muted);
  }
  .card h2 .count {
    background: var(--green-soft); color: var(--green-dark); border-radius: 999px;
    padding: 2px 9px; font-size: 11px; margin-left: 6px; text-transform: none; letter-spacing: 0;
  }

  /* ---------------- Chips ---------------- */
  .chips { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 8px; }
  .chip {
    display: inline-flex; align-items: center; gap: 7px;
    background: var(--green-soft); color: var(--green-darker);
    padding: 5px 10px; border-radius: 999px; font-size: 13px; font-weight: 500;
  }
  .chip form { display: inline-flex; margin: 0; }
  .chip button {
    background: none; border: none; color: var(--green-dark); cursor: pointer;
    padding: 0 0 0 2px; font-size: 15px; line-height: 1; opacity: 0.6;
  }
  .chip button:hover { opacity: 1; color: var(--red); }
  .inline-add { display: flex; gap: 7px; margin-top: 8px; }
  .inline-add input {
    flex: 1; padding: 9px 12px; border: 1px solid var(--border-strong);
    border-radius: 9px; font-size: 13px; font-family: inherit;
  }
  .inline-add input:focus { outline: none; border-color: var(--green); }
  .inline-add button {
    padding: 9px 13px; background: var(--green); color: white; border: none;
    border-radius: 9px; font-size: 15px; cursor: pointer; line-height: 1;
  }
  .inline-add button:hover { background: var(--green-dark); }

  /* ---------------- Badges ---------------- */
  .badge {
    font-size: 11px; font-weight: 700; padding: 3px 9px; border-radius: 999px;
    background: var(--cream); color: var(--muted); white-space: nowrap;
  }
  .badge.hot { background: var(--red-soft); color: var(--red); }
  .badge.investigate { background: var(--blue-soft); color: var(--blue); }
  .badge.watch { background: var(--amber-soft); color: var(--amber); }
  .badge.new { background: var(--green); color: white; }
  .feedback-tag { font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 6px; }
  .feedback-tag.contacted { background: var(--red-soft); color: var(--red); }
  .feedback-tag.relevant { background: var(--green-soft); color: var(--green-dark); }
  .feedback-tag.not_relevant { background: var(--cream); color: var(--muted); }

  .empty { text-align: center; color: var(--muted); padding: 40px 16px; font-size: 14px; }

  /* ---------------- Toast ---------------- */
  .toast {
    position: fixed; bottom: 24px; right: 24px; background: white;
    border: 1px solid var(--border); border-radius: 14px; padding: 14px 18px;
    box-shadow: var(--shadow); max-width: 400px; z-index: 100; font-size: 13px;
  }
  .toast.running { border-left: 4px solid var(--green); }
  .toast.done { border-left: 4px solid var(--green-dark); }
  .toast.failed { border-left: 4px solid var(--red); }
  .toast .title { font-weight: 700; margin-bottom: 4px; }
  .toast .body { color: var(--muted); font-size: 12.5px; }
  .hidden { display: none !important; }
  {% block extra_css %}{% endblock %}
</style>
</head>
<body>

<header class="appbar">
  <a href="/" class="brand"><span class="logo">S</span> Signal Tracker</a>
  <nav class="nav">
    <a href="/" class="{% block nav_search %}{% endblock %}">Recherche</a>
    <a href="/results" class="{% block nav_results %}{% endblock %}">Résultats</a>
  </nav>
  <div class="spacer"></div>
  <span id="status-pill" class="status-pill {{ task_status }}">
    {% if task_status == "running" %}<span class="spinner"></span> Analyse en cours…
    {% elif task_status == "done" %}Dernière analyse terminée
    {% elif task_status == "failed" %}Échec
    {% else %}Prêt{% endif %}
  </span>
</header>

<main>
  {% block content %}{% endblock %}
</main>

<div id="toast" class="toast hidden">
  <div class="title" id="toast-title">Analyse en cours…</div>
  <div class="body" id="toast-body"></div>
</div>

<script>
(function () {
  const pill = document.getElementById('status-pill');
  const toast = document.getElementById('toast');
  const toastTitle = document.getElementById('toast-title');
  const toastBody = document.getElementById('toast-body');
  if (!pill) return;
  let polling = null;
  let lastStatus = pill.className.replace('status-pill', '').trim() || 'idle';
  const stepLabels = { collect: 'Collecte des sources…', classify: 'Analyse IA des signaux…' };

  function fmtMetrics(m) {
    if (!m) return '';
    const parts = [];
    if (m.collect) parts.push(`Collecte : ${m.collect.fetched} articles · ${m.collect.new} nouveaux`);
    if (m.classify) parts.push(`Analyse : ${m.classify.processed} traités · ${m.classify.signals_created} signaux · ${m.classify.errors} erreurs`);
    return parts.join('<br>');
  }
  function apply(state) {
    const status = state.status || 'idle';
    pill.className = 'status-pill ' + status;
    if (status === 'running') {
      pill.innerHTML = '<span class="spinner"></span> ' + (stepLabels[state.step] || 'Analyse en cours…');
      toast.classList.remove('hidden'); toast.className = 'toast running';
      toastTitle.textContent = stepLabels[state.step] || 'Analyse en cours…';
      toastBody.innerHTML = fmtMetrics(state.metrics) || 'Démarrage…';
    } else if (status === 'done') {
      pill.textContent = 'Dernière analyse terminée';
      toast.classList.remove('hidden'); toast.className = 'toast done';
      toastTitle.textContent = 'Analyse terminée ✓';
      const rid = state.current_run_id;
      const link = rid ? `/results?run=${rid}` : '/results';
      toastBody.innerHTML = fmtMetrics(state.metrics) + `<br><a href="${link}">Voir les résultats →</a>`;
      stop();
      if (lastStatus === 'running') setTimeout(() => {
        const rid2 = state.current_run_id;
        window.location.href = rid2 ? `/results?run=${rid2}` : '/results';
      }, 1500);
    } else if (status === 'failed') {
      pill.textContent = 'Échec';
      toast.classList.remove('hidden'); toast.className = 'toast failed';
      toastTitle.textContent = 'Analyse échouée';
      toastBody.textContent = state.error || 'Erreur inconnue';
      stop();
    }
    lastStatus = status;
  }
  function poll() { fetch('/run/status').then(r => r.json()).then(apply).catch(() => {}); }
  function start() { if (!polling) { polling = setInterval(poll, 2000); poll(); } }
  function stop() { if (polling) { clearInterval(polling); polling = null; } }
  if (lastStatus === 'running') start();
  window.__startStatusPolling = start;
})();
</script>
{% block extra_js %}{% endblock %}
</body>
</html>
