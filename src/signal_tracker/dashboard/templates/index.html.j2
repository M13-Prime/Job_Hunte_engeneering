<!doctype html>
<html lang="fr">
<head>
<meta charset="utf-8">
<title>Signal Tracker</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #f7f8fa;
    --card: #ffffff;
    --text: #0f172a;
    --muted: #64748b;
    --muted-2: #94a3b8;
    --border: #e2e8f0;
    --border-strong: #cbd5e1;
    --accent: #1d4ed8;
    --accent-hover: #1e40af;
    --hot: #b91c1c;
    --hot-bg: #fef2f2;
    --inv: #1d4ed8;
    --inv-bg: #eff6ff;
    --watch: #92400e;
    --watch-bg: #fffbeb;
    --success: #047857;
    --success-bg: #ecfdf5;
    --neutral-bg: #f1f5f9;
  }
  * { box-sizing: border-box; }
  html, body { height: 100%; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* ---------- Header ---------- */
  header.appbar {
    background: white;
    border-bottom: 1px solid var(--border);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .appbar .brand {
    font-weight: 700;
    font-size: 18px;
    letter-spacing: -0.01em;
  }
  .appbar .brand .dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--accent);
    margin-right: 6px;
    vertical-align: middle;
  }
  .appbar .totals {
    display: flex;
    gap: 18px;
    margin-left: 12px;
    color: var(--muted);
    font-size: 13px;
  }
  .appbar .totals strong { color: var(--text); }
  .appbar .spacer { flex: 1; }
  .appbar .launch {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: white;
    border: none;
    padding: 9px 16px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 120ms ease;
  }
  .appbar .launch:hover { background: var(--accent-hover); }
  .appbar .launch:disabled {
    background: var(--muted-2);
    cursor: not-allowed;
  }
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 500;
    background: var(--neutral-bg);
    color: var(--muted);
  }
  .status-pill.running {
    background: var(--inv-bg);
    color: var(--inv);
  }
  .status-pill.done { background: var(--success-bg); color: var(--success); }
  .status-pill.failed { background: var(--hot-bg); color: var(--hot); }
  .spinner {
    width: 12px; height: 12px;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ---------- Layout ---------- */
  main {
    max-width: 1400px;
    margin: 24px auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 24px;
  }
  @media (max-width: 1024px) {
    main { grid-template-columns: 1fr; }
  }

  /* ---------- Panels ---------- */
  .panel {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px 20px;
    margin-bottom: 16px;
  }
  .panel h2 {
    margin: 0 0 12px;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
  }
  .panel h2 .count {
    background: var(--neutral-bg);
    color: var(--muted);
    border-radius: 999px;
    padding: 2px 8px;
    font-size: 11px;
    margin-left: 6px;
    text-transform: none;
    letter-spacing: 0;
  }

  /* ---------- Filters ---------- */
  .filters form {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }
  .filters label {
    font-size: 12px;
    color: var(--muted);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .filters input, .filters select {
    padding: 7px 10px;
    border: 1px solid var(--border-strong);
    border-radius: 7px;
    font-size: 13px;
    background: white;
  }
  .filters button {
    padding: 7px 14px;
    background: var(--text);
    color: white;
    border: none;
    border-radius: 7px;
    font-size: 13px;
    cursor: pointer;
  }
  .filters button:hover { opacity: 0.9; }

  /* ---------- Signal cards ---------- */
  .signal {
    padding: 16px 0;
    border-top: 1px solid var(--border);
  }
  .signal:first-of-type { border-top: 0; padding-top: 4px; }
  .signal-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 4px;
  }
  .signal-head .company {
    font-weight: 600;
    font-size: 16px;
    flex: 1;
    word-break: break-word;
  }
  .badge {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 999px;
    background: var(--neutral-bg);
    color: var(--muted);
    white-space: nowrap;
  }
  .badge.hot { background: var(--hot-bg); color: var(--hot); }
  .badge.investigate { background: var(--inv-bg); color: var(--inv); }
  .badge.watch { background: var(--watch-bg); color: var(--watch); }
  .signal-meta {
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .signal-summary {
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--text);
    margin: 6px 0;
  }
  .signal-angle {
    background: var(--inv-bg);
    border-left: 3px solid var(--accent);
    padding: 8px 12px;
    border-radius: 4px;
    margin: 8px 0;
    font-size: 13px;
  }
  .signal-angle strong { color: var(--accent); }
  .signal-contact {
    font-size: 13px;
    color: var(--text);
    margin: 4px 0;
  }
  .signal-actions {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 10px;
  }
  .signal-actions form { margin: 0; }
  .btn-action {
    padding: 5px 11px;
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    background: white;
    font-size: 12px;
    cursor: pointer;
    font-weight: 500;
    color: var(--muted);
    transition: all 120ms;
  }
  .btn-action:hover { border-color: var(--text); color: var(--text); }
  .btn-action.contacted { border-color: var(--hot); color: var(--hot); }
  .btn-action.contacted:hover { background: var(--hot-bg); }
  .btn-action.relevant { border-color: var(--inv); color: var(--inv); }
  .btn-action.relevant:hover { background: var(--inv-bg); }
  .btn-action.not_relevant { color: var(--muted); }
  .btn-action.source {
    border: 1px solid transparent;
    color: var(--accent);
    font-weight: 600;
  }
  .feedback-tag {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 4px;
  }
  .feedback-tag.contacted { background: var(--hot-bg); color: var(--hot); }
  .feedback-tag.relevant { background: var(--inv-bg); color: var(--inv); }
  .feedback-tag.not_relevant { background: var(--neutral-bg); color: var(--muted); }
  .empty {
    text-align: center;
    color: var(--muted);
    padding: 32px 12px;
    font-size: 14px;
  }

  /* ---------- Sidebar ---------- */
  .sidebar .panel { padding: 16px 18px; }
  .kw-group { margin-bottom: 14px; }
  .kw-group:last-child { margin-bottom: 0; }
  .kw-group .label {
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 6px;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 6px;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--neutral-bg);
    color: var(--text);
    padding: 4px 8px;
    border-radius: 999px;
    font-size: 12.5px;
  }
  .chip form { display: inline-flex; margin: 0; }
  .chip button {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    padding: 0 0 0 2px;
    font-size: 14px;
    line-height: 1;
  }
  .chip button:hover { color: var(--hot); }
  .kw-add {
    display: flex;
    gap: 6px;
    margin-top: 6px;
  }
  .kw-add input {
    flex: 1;
    padding: 6px 10px;
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    font-size: 13px;
  }
  .kw-add button {
    padding: 6px 10px;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 13px;
    cursor: pointer;
  }
  .kw-add button:hover { background: var(--accent-hover); }

  /* Watchlist (similar to keywords) */
  .watchlist ul {
    list-style: none;
    padding: 0;
    margin: 0 0 8px;
  }
  .watchlist li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 0;
    font-size: 13.5px;
    border-top: 1px solid var(--border);
  }
  .watchlist li:first-child { border-top: 0; }
  .watchlist li .notes { color: var(--muted); font-size: 12px; margin-left: 4px; }
  .watchlist form.del button {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 12px;
  }
  .watchlist form.del button:hover { color: var(--hot); }
  .watchlist .add { display: flex; gap: 6px; margin-top: 8px; }
  .watchlist .add input {
    flex: 1;
    padding: 6px 10px;
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    font-size: 13px;
  }
  .watchlist .add button {
    padding: 6px 10px;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 13px;
    cursor: pointer;
  }

  /* ---------- Toast ---------- */
  .toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    background: white;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    max-width: 380px;
    z-index: 100;
    font-size: 13px;
  }
  .toast.running { border-left: 4px solid var(--accent); }
  .toast.done { border-left: 4px solid var(--success); }
  .toast.failed { border-left: 4px solid var(--hot); }
  .toast .title { font-weight: 600; margin-bottom: 4px; }
  .toast .body { color: var(--muted); font-size: 12.5px; line-height: 1.4; }
  .hidden { display: none !important; }
</style>
</head>
<body>

<header class="appbar">
  <div class="brand"><span class="dot"></span> Signal Tracker</div>
  <div class="totals">
    <span><strong>{{ totals.signals }}</strong> signaux</span>
    <span><strong>{{ totals.pending }}</strong> à traiter</span>
    <span><strong>{{ totals.companies }}</strong> entreprises</span>
  </div>
  <div class="spacer"></div>

  <span id="status-pill" class="status-pill {{ task_status }}">
    {% if task_status == "running" %}
      <span class="spinner"></span> Pipeline en cours…
    {% elif task_status == "done" %}
      Pipeline terminée
    {% elif task_status == "failed" %}
      Échec
    {% else %}
      En attente
    {% endif %}
  </span>

  <form method="post" action="/run/pipeline" style="margin: 0;">
    <button type="submit" class="launch" id="launch-btn"
            {% if task_status == "running" %}disabled{% endif %}>
      ▶ Lancer la recherche
    </button>
  </form>
</header>

<main>

  <!-- Left column: filters + signals -->
  <section class="content">

    <div class="panel filters">
      <form method="get" action="/">
        <label>Feedback
          <select name="feedback">
            <option value="" {% if filter_feedback == "" %}selected{% endif %}>tous</option>
            <option value="pending" {% if filter_feedback == "pending" %}selected{% endif %}>sans feedback</option>
            {% for f in valid_feedback %}
            <option value="{{ f }}" {% if filter_feedback == f %}selected{% endif %}>{{ f }}</option>
            {% endfor %}
          </select>
        </label>
        <label>Score min
          <input type="number" name="min_score" value="{{ min_score }}" min="0" max="100" step="1" style="width: 70px;">
        </label>
        <button type="submit">Filtrer</button>
      </form>
    </div>

    <div class="panel">
      <h2>Signaux <span class="count">{{ rows|length }}</span></h2>

      {% if not rows %}
      <div class="empty">
        Aucun signal pour ces filtres. Clique <strong>« Lancer la recherche »</strong> en haut à droite pour collecter et classer.
      </div>
      {% endif %}

      {% for signal, raw in rows %}
      {% set badge = "hot" if signal.total_score >= 80 else ("investigate" if signal.total_score >= 60 else "watch") %}
      <div class="signal">
        <div class="signal-head">
          <span class="company">{{ signal.company_name or "(sans nom)" }}</span>
          <span class="badge {{ badge }}">{{ "%.1f"|format(signal.total_score) }} · {{ signal.signal_type }}</span>
        </div>
        <div class="signal-meta">
          {{ raw.source }}
          · {{ signal.recommended_action }}
          {% if signal.user_feedback %}· <span class="feedback-tag {{ signal.user_feedback }}">{{ signal.user_feedback }}</span>{% endif %}
        </div>
        <div class="signal-summary">{{ signal.summary_fr }}</div>
        {% if signal.suggested_angle %}
        <div class="signal-angle"><strong>Angle :</strong> {{ signal.suggested_angle }}</div>
        {% endif %}
        {% if signal.target_contact %}
          {% set c = signal.target_contact %}
          {% if c.name or c.role %}
          <div class="signal-contact">
            <strong>Contact :</strong>
            {% if c.name %}{{ c.name }}{% endif %}
            {% if c.role %} — {{ c.role }}{% endif %}
            {% if c.rationale %}<span style="color: var(--muted);">({{ c.rationale }})</span>{% endif %}
          </div>
          {% endif %}
        {% endif %}
        <div class="signal-actions">
          {% if raw.url %}
          <a href="{{ raw.url }}" target="_blank" rel="noopener" class="btn-action source">Source ↗</a>
          {% endif %}
          <form method="post" action="/signals/{{ signal.id }}/feedback"><input type="hidden" name="action" value="contacted"><button type="submit" class="btn-action contacted">Contacté</button></form>
          <form method="post" action="/signals/{{ signal.id }}/feedback"><input type="hidden" name="action" value="relevant"><button type="submit" class="btn-action relevant">Pertinent</button></form>
          <form method="post" action="/signals/{{ signal.id }}/feedback"><input type="hidden" name="action" value="not_relevant"><button type="submit" class="btn-action not_relevant">Pas pertinent</button></form>
        </div>
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- Right column: sidebar with keywords + watchlist -->
  <aside class="sidebar">

    <div class="panel">
      <h2>Mots-clés de chasse</h2>

      {% set cat_labels = {"field": "Domaines / secteurs", "job_title": "Postes ciblés", "other": "Autres mots-clés"} %}
      {% set cat_hints = {"field": "ex: AI for legal, climate tech", "job_title": "ex: Sales Engineer, Climate Data Scientist", "other": "ex: AI Act, RAG, CSRD"} %}

      {% for cat in keyword_categories %}
      <div class="kw-group">
        <div class="label">{{ cat_labels[cat] }} <span style="color: var(--muted-2); font-weight: 400; text-transform: none; letter-spacing: 0;">· {{ keywords_by_cat[cat]|length }}</span></div>
        {% if keywords_by_cat[cat] %}
        <div class="chips">
          {% for kw in keywords_by_cat[cat] %}
          <span class="chip">
            {{ kw.value }}
            <form method="post" action="/keywords/{{ kw.id }}/delete">
              <button type="submit" title="Supprimer">×</button>
            </form>
          </span>
          {% endfor %}
        </div>
        {% endif %}
        <form class="kw-add" method="post" action="/keywords">
          <input type="hidden" name="category" value="{{ cat }}">
          <input type="text" name="value" placeholder="{{ cat_hints[cat] }}" required maxlength="255">
          <button type="submit" title="Ajouter">+</button>
        </form>
      </div>
      {% endfor %}

      <div style="font-size: 11.5px; color: var(--muted); margin-top: 12px; padding-top: 12px; border-top: 1px dashed var(--border);">
        💡 Ces mots-clés sont injectés dans le prompt du classifier dès le prochain run. Ils complètent ton <code style="background: var(--neutral-bg); padding: 1px 5px; border-radius: 3px;">user_profile.yaml</code>.
      </div>
    </div>

    <div class="panel watchlist">
      <h2>Watchlist <span class="count">{{ watchlist|length }}</span></h2>
      {% if not watchlist %}
      <div style="color: var(--muted); font-size: 13px; margin-bottom: 8px;">Aucune entreprise prioritaire.</div>
      {% endif %}
      <ul>
        {% for entry in watchlist %}
        <li>
          <span>
            <strong>{{ entry.company_name }}</strong>
            {% if entry.notes %}<span class="notes">— {{ entry.notes }}</span>{% endif %}
          </span>
          <form method="post" action="/watchlist/{{ entry.id }}/delete" class="del">
            <button type="submit">×</button>
          </form>
        </li>
        {% endfor %}
      </ul>
      <form method="post" action="/watchlist" class="add">
        <input type="text" name="company_name" placeholder="Nom d'entreprise" required maxlength="500">
        <input type="text" name="notes" placeholder="Notes (option.)" maxlength="500">
        <button type="submit">Ajouter</button>
      </form>
    </div>

  </aside>
</main>

<!-- Status toast (shown while pipeline is running) -->
<div id="toast" class="toast hidden">
  <div class="title" id="toast-title">Pipeline en cours…</div>
  <div class="body" id="toast-body"></div>
</div>

<script>
(function () {
  // Live status polling. Starts as soon as the page loads with status=running,
  // or right after the user clicks "Launch search".
  const pill = document.getElementById('status-pill');
  const btn = document.getElementById('launch-btn');
  const toast = document.getElementById('toast');
  const toastTitle = document.getElementById('toast-title');
  const toastBody = document.getElementById('toast-body');
  let polling = null;
  let lastStatus = pill ? pill.className.replace('status-pill ', '').trim() : 'idle';

  const stepLabels = {
    collect: 'Collecte RSS / GDELT…',
    classify: 'Classification LLM…',
    digest: 'Génération du digest…',
  };

  function fmtMetrics(metrics) {
    if (!metrics) return '';
    const parts = [];
    if (metrics.collect) {
      parts.push(`Collect: ${metrics.collect.fetched} fetched · ${metrics.collect.new} nouveaux`);
    }
    if (metrics.classify) {
      parts.push(`Classify: ${metrics.classify.processed} processés · ${metrics.classify.signals_created} signaux · ${metrics.classify.errors} erreurs`);
    }
    return parts.join('<br>');
  }

  function applyStatus(state) {
    const status = state.status || 'idle';

    // Update pill
    pill.className = 'status-pill ' + status;
    if (status === 'running') {
      const stepText = stepLabels[state.step] || 'Pipeline en cours…';
      pill.innerHTML = '<span class="spinner"></span> ' + stepText;
      btn.disabled = true;
      toast.classList.remove('hidden');
      toast.className = 'toast running';
      toastTitle.textContent = stepText;
      toastBody.innerHTML = fmtMetrics(state.metrics) || 'Démarrage…';
    } else if (status === 'done') {
      pill.textContent = 'Pipeline terminée';
      btn.disabled = false;
      toast.classList.remove('hidden');
      toast.className = 'toast done';
      toastTitle.textContent = 'Pipeline terminée ✓';
      toastBody.innerHTML = fmtMetrics(state.metrics) + '<br><a href="/">Rafraîchir pour voir les signaux</a>';
      stopPolling();
      // Auto-refresh once when the pipeline transitions to done.
      if (lastStatus === 'running') {
        setTimeout(() => window.location.reload(), 1500);
      }
    } else if (status === 'failed') {
      pill.textContent = 'Échec';
      btn.disabled = false;
      toast.classList.remove('hidden');
      toast.className = 'toast failed';
      toastTitle.textContent = 'Pipeline échouée';
      toastBody.textContent = state.error || 'Erreur inconnue';
      stopPolling();
    } else {
      pill.textContent = 'En attente';
      btn.disabled = false;
    }
    lastStatus = status;
  }

  function poll() {
    fetch('/run/status').then(r => r.json()).then(applyStatus).catch(() => {});
  }

  function startPolling() {
    if (polling) return;
    polling = setInterval(poll, 2000);
    poll();
  }

  function stopPolling() {
    if (polling) {
      clearInterval(polling);
      polling = null;
    }
  }

  // If the server reports running on initial load, start polling now.
  if (lastStatus === 'running') {
    startPolling();
  }

  // Intercept the "Launch" form submit so we can start polling right away.
  const launchForm = btn ? btn.closest('form') : null;
  if (launchForm) {
    launchForm.addEventListener('submit', () => {
      // The server still does its redirect; we just kick off polling early.
      setTimeout(startPolling, 500);
    });
  }
})();
</script>

</body>
</html>
