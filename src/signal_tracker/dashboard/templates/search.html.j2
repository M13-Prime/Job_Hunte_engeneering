{% extends "base.html.j2" %}
{% block title %}Signal Tracker — Lancer une recherche{% endblock %}
{% block nav_search %}active{% endblock %}

{% block extra_css %}
  .hero { text-align: center; padding: 28px 0 8px; }
  .hero h1 { font-size: 34px; font-weight: 800; color: var(--green-darker); margin: 0 0 8px; }
  .hero p { color: var(--muted); font-size: 16px; max-width: 620px; margin: 0 auto; }
  .grid { display: grid; grid-template-columns: minmax(0,1fr) 360px; gap: 24px; margin-top: 24px; align-items: start; }
  @media (max-width: 960px) { .grid { grid-template-columns: 1fr; } }
  .kw-group { margin-bottom: 18px; }
  .kw-group:last-of-type { margin-bottom: 0; }
  .kw-label { font-size: 13px; font-weight: 700; color: var(--ink); margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }
  .kw-label .pill { font-weight: 500; font-size: 11px; color: var(--muted); background: var(--cream); border-radius: 999px; padding: 2px 8px; }
  .launch-row { margin-top: 22px; padding-top: 20px; border-top: 1px solid var(--border); display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
  .launch-row .hint { color: var(--muted); font-size: 13px; }
  .runs li { list-style: none; }
  .runs ul { padding: 0; margin: 0; }
  .run-item {
    display: flex; align-items: center; gap: 12px; padding: 12px 0;
    border-top: 1px solid var(--border); font-size: 13.5px;
  }
  .run-item:first-child { border-top: 0; }
  .run-item .dot { width: 8px; height: 8px; border-radius: 999px; flex-shrink: 0; }
  .run-item .dot.done { background: var(--green); }
  .run-item .dot.running { background: var(--amber); }
  .run-item .dot.failed { background: var(--red); }
  .run-item .meta { flex: 1; min-width: 0; }
  .run-item .meta .label { font-weight: 600; color: var(--ink); }
  .run-item .meta .sub { color: var(--muted); font-size: 12px; }
  .run-item .del { background: none; border: none; color: var(--muted-2); cursor: pointer; font-size: 14px; }
  .run-item .del:hover { color: var(--red); }
{% endblock %}

{% block content %}
<div class="hero">
  <h1>Détecte qui va recruter, avant tout le monde.</h1>
  <p>Définis tes mots-clés de chasse, lance l'analyse, et reçois une liste classée
     d'entreprises à contacter — nominations de dirigeants, levées de fonds, signaux ESG &amp; IA.</p>
</div>

<div class="grid">

  <!-- Left: keyword editor + launch -->
  <div class="card">
    <h2>Mots-clés de la recherche</h2>

    {% set cat_labels = {"field": "Domaines / secteurs", "job_title": "Postes ciblés", "other": "Autres mots-clés"} %}
    {% set cat_hints = {"field": "ex : climate tech, AI for sustainability", "job_title": "ex : Sales Engineer, Climate Data Scientist", "other": "ex : CSRD, AI Act, RAG"} %}

    {% for cat in keyword_categories %}
    <div class="kw-group">
      <div class="kw-label">{{ cat_labels[cat] }} <span class="pill">{{ keywords_by_cat[cat]|length }}</span></div>
      {% if keywords_by_cat[cat] %}
      <div class="chips">
        {% for kw in keywords_by_cat[cat] %}
        <span class="chip">{{ kw.value }}
          <form method="post" action="/keywords/{{ kw.id }}/delete"><button type="submit" title="Supprimer">×</button></form>
        </span>
        {% endfor %}
      </div>
      {% endif %}
      <form class="inline-add" method="post" action="/keywords">
        <input type="hidden" name="category" value="{{ cat }}">
        <input type="text" name="value" placeholder="{{ cat_hints[cat] }}" required maxlength="255">
        <button type="submit" title="Ajouter">+</button>
      </form>
    </div>
    {% endfor %}

    <div class="launch-row">
      <form method="post" action="/search" id="launch-form" style="margin:0;">
        <button type="submit" class="btn btn-primary btn-lg" id="launch-btn"
                {% if task_status == "running" %}disabled{% endif %}>
          ▶ Lancer la recherche
        </button>
      </form>
      <span class="hint">
        {% if task_status == "running" %}Une analyse est déjà en cours…
        {% else %}Collecte ~500-900 articles puis les classe par IA (~5-15 min).{% endif %}
      </span>
    </div>
  </div>

  <!-- Right: history + watchlist -->
  <div>
    <div class="card runs" style="margin-bottom: 20px;">
      <h2>Recherches précédentes <span class="count">{{ runs|length }}</span></h2>
      {% if not runs %}
      <div class="empty" style="padding: 20px 8px;">Aucune recherche encore. Lance la première !</div>
      {% else %}
      <ul>
        {% for run in runs %}
        <li>
          <div class="run-item">
            <span class="dot {{ run.status }}"></span>
            <div class="meta">
              <div class="label"><a href="/results?run={{ run.id }}">{{ run.label }}</a></div>
              <div class="sub">
                {{ run.created_at.strftime("%d/%m %H:%M") if run.created_at else "" }}
                {% if run.metrics and run.metrics.classify %}· {{ run.metrics.classify.signals_created }} signaux{% endif %}
                {% if run.status == "running" %}· en cours…{% elif run.status == "failed" %}· échec{% endif %}
              </div>
            </div>
            <form method="post" action="/searches/{{ run.id }}/delete"><button class="del" type="submit" title="Supprimer">×</button></form>
          </div>
        </li>
        {% endfor %}
      </ul>
      {% endif %}
      <div style="margin-top:14px;">
        <a href="/results" class="btn btn-ghost" style="width:100%;">Voir tous les signaux ({{ total_signals }})</a>
      </div>
    </div>

    <div class="card">
      <h2>Watchlist <span class="count">{{ watchlist|length }}</span></h2>
      {% if not watchlist %}
      <div style="color:var(--muted); font-size:13px; margin-bottom:8px;">Aucune entreprise prioritaire.</div>
      {% else %}
      <div class="chips">
        {% for entry in watchlist %}
        <span class="chip">{{ entry.company_name }}
          <form method="post" action="/watchlist/{{ entry.id }}/delete"><button type="submit" title="Supprimer">×</button></form>
        </span>
        {% endfor %}
      </div>
      {% endif %}
      <form class="inline-add" method="post" action="/watchlist">
        <input type="text" name="company_name" placeholder="Nom d'entreprise" required maxlength="500">
        <button type="submit" title="Ajouter">+</button>
      </form>
    </div>
  </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
  // Start live polling as soon as the search is launched.
  var f = document.getElementById('launch-form');
  if (f) f.addEventListener('submit', function () {
    setTimeout(function () { if (window.__startStatusPolling) window.__startStatusPolling(); }, 500);
  });
</script>
{% endblock %}
